# Copy to .env and fill in values. .env is gitignored, so
# machine-specific paths and keys won't get committed.

# API Keys
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY_SF_PM=sk-ant-...   # fallback if ANTHROPIC_API_KEY is unset

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=archaeology

# Models
NER_MODEL=claude-sonnet-4-20250514
CLEANUP_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v2-moe
EMBEDDING_DIM=768

# Chunking
CHUNK_SIZE=1500
CHUNK_OVERLAP=200

# Paths (relative to project root)
DATA_DIR=data
PDF_DIR=data/pdf
MD_DIR=data/md
SHACL_PATH=shacl/virginia-archaeology.shacl.ttl
